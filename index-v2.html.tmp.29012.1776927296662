        <button class="ai-chip primary" onclick="aiAsk('WORK FEST 추천')">WORK FEST 추천</button>
      </div>
    </div>
    <div id="ai-input-row">
      <input id="ai-input" placeholder="질문을 입력하세요 (곧 자연어 지원)" onkeydown="if(event.key==='Enter')aiAsk(this.value)">
      <button id="ai-send" onclick="aiAsk(document.getElementById('ai-input').value)">전송</button>
    </div>
  </div>

  <script>
    // Top nav sticky background
    (function() {
      const nav = document.getElementById('topnav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 8) nav.classList.add('is-stuck');
        else nav.classList.remove('is-stuck');
      }, { passive: true });
    })();

    // Nav section active highlight
    (function() {
      const links = document.querySelectorAll('.nav-menu a[data-nav]');
      const sections = Array.from(links).map(l => document.querySelector(l.getAttribute('href')));
      function onScroll() {
        const y = window.scrollY + 100;
        let active = 0;
        sections.forEach((s, i) => { if (s && s.offsetTop <= y) active = i; });
        links.forEach((l, i) => l.classList.toggle('is-active', i === active));
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();

    // D-Day for WORK FEST (2026-05-01)
    (function() {
      const target = new Date('2026-05-01');
      const now = new Date(); now.setHours(0,0,0,0);
      const diff = Math.ceil((target - now) / 86400000);
      const el = document.getElementById('workfestDday');
      if (el) {
        if (diff > 0) el.textContent = 'D-' + diff;
        else if (diff === 0) el.textContent = 'D-Day';
        else el.textContent = '진행 중';
      }
    })();

    // AI chat (placeholder)
    function toggleAi() {
      document.getElementById('ai-panel').classList.toggle('is-open');
    }
    function aiAsk(q) {
      if (!q || !q.trim()) return;
      const msgs = document.getElementById('ai-msgs');
      // remove initial chips row
      const chips = msgs.querySelector('.ai-chips');
      if (chips) chips.remove();
      const u = document.createElement('div'); u.className = 'msg user'; u.textContent = q; msgs.appendChild(u);
      setTimeout(() => {
        const b = document.createElement('div'); b.className = 'msg bot';
        const A = {
          '데브콘 성과': '✅ DEVCON · 신청 1,511 (KPI 100.7%) · 이력서 156 (104%) · CPC 174원 (vs 커컨 428원, ↓59%)',
          '커리어 컨퍼런스': '📊 커컨 · 신청 1,566 (KPI 31.5%) · 이력서 110 · 실참석 562 · 만족도 4.33/5',
          'WORK FEST 추천': '🎯 목표 신청 2,000 · 이력서 500 · 예산 1,400만 원<br>→ 권장 광고비 350~500만 (데브콘 효율 기준)'
        };
        b.innerHTML = A[q] || '자연어 챗봇은 LLM 연동 후 지원 예정이에요. 지금은 키워드(데브콘/커리어컨퍼런스/WORK FEST) 위주로 답변해요.';
        msgs.appendChild(b);
        msgs.scrollTop = msgs.scrollHeight;
      }, 300);
      document.getElementById('ai-input').value = '';
    }

    // === 실시간 데브콘 API (기존 index.html과 동일) ===
    (async function() {
      try {
        const API_URL = (location.hostname === 'localhost' || location.protocol === 'file:')
          ? 'https://b2c-dashboard-sigma.vercel.app/api/devcon-data'
          : '/api/devcon-data';
        const res = await fetch(API_URL, { signal: AbortSignal.timeout ? AbortSignal.timeout(5000) : undefined });
        if (!res.ok) return;
        const d = await res.json();
        if (d.error) return;
        const total = 1566 + d.total, resume = 110 + (d.resume || 0);
        document.getElementById('heroTotal').textContent = total.toLocaleString();
        document.getElementById('heroResume').textContent = resume.toLocaleString() + '명';
        document.getElementById('totalApplicants').textContent = total.toLocaleString();
        document.getElementById('totalResume').textContent = resume.toLocaleString();
        document.getElementById('totalApplicantsSub').textContent = '커컨 1,566 · 데브콘 ' + d.total.toLocaleString();
        document.getElementById('totalResumeSub').textContent = '커컨 110 · 데브콘 ' + (d.resume || 0).toLocaleString();
        if (d.updateTime) document.getElementById('navUpdate').textContent = d.updateTime + ' 기준';
      } catch (err) { /* 정적 유지 */ }
    })();
  </script>
</body>
