<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>인사이트전략팀 · B2C 성과</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css">
  <style>
    /* === Design tokens === */
    :root {
      --c-bg: #FFFFFF;
      --c-surface: #FFFFFF;
      --c-surface-alt: #F9FAFB;
      --c-surface-deep: #F2F4F6;
      --c-border: #F2F4F6;
      --c-border-strong: #E5E8EB;
      --c-text: #191F28;
      --c-text-2: #4E5968;
      --c-text-3: #8B95A1;
      --c-text-4: #B0B8C1;
      --c-primary: #3182F6;
      --c-primary-hover: #1B64DA;
      --c-primary-bg: #E8F3FF;
      --c-primary-deep: #0E4BC9;
      --c-navy: #0F1A30;
      --c-success: #00C896;
      --c-success-bg: #E5F9F4;
      --c-warning: #FFB700;
      --c-warning-bg: #FFF7E0;
      --c-danger: #F04452;
      --c-danger-bg: #FFEBEC;

      --r-sm: 10px; --r-md: 14px; --r-lg: 20px; --r-xl: 28px; --r-pill: 999px;
      --sh-1: 0 2px 6px rgba(15,19,36,0.04);
      --sh-2: 0 8px 24px rgba(15,19,36,0.08);
      --sh-3: 0 16px 48px rgba(15,19,36,0.12);
      --nav-h: 68px;
      --tx-mono: "tnum" on, "lnum" on;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-padding-top: var(--nav-h); }
    body {
      font-family: 'Pretendard', -apple-system, sans-serif;
      background: var(--c-bg); color: var(--c-text);
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
    }
    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

    /* ────────────────────────────────────────────────
       Top Nav
    ──────────────────────────────────────────────── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: var(--nav-h);
      background: rgba(255,255,255,0);
      backdrop-filter: blur(0);
      transition: background 0.3s, box-shadow 0.3s, backdrop-filter 0.3s;
    }
    .nav.is-stuck {
      background: rgba(255,255,255,0.88);
      backdrop-filter: saturate(180%) blur(20px);
      box-shadow: 0 1px 0 var(--c-border);
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 32px;
      height: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-brand {
      font-size: 17px; font-weight: 800; color: var(--c-text); letter-spacing: -0.01em;
    }
    .nav-brand .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--c-primary); margin-right: 8px; vertical-align: middle; }
    .nav-menu { display: flex; gap: 4px; align-items: center; list-style: none; }
    .nav-menu a {
      font-size: 15px; font-weight: 600; color: var(--c-text-2);
      padding: 10px 16px; border-radius: 10px;
      transition: color 0.12s, background 0.12s;
    }
    .nav-menu a:hover { color: var(--c-text); background: var(--c-surface-deep); }
    .nav-menu a.is-active { color: var(--c-primary); }
    .nav-actions { display: flex; gap: 10px; align-items: center; }
    .nav-update { font-size: 12px; color: var(--c-text-3); font-weight: 500; font-feature-settings: var(--tx-mono); }

    /* ────────────────────────────────────────────────
       Hero
    ──────────────────────────────────────────────── */
    .hero {
      padding: calc(var(--nav-h) + 96px) 0 96px;
      background: linear-gradient(180deg, #F5F9FF 0%, #FFFFFF 100%);
    }
    .hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 56px; align-items: center; }
    .hero-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 12px; font-weight: 700; color: var(--c-primary);
      background: var(--c-primary-bg); padding: 6px 14px; border-radius: var(--r-pill);
      margin-bottom: 24px; letter-spacing: 0.02em;
    }
    .hero h1 {
      font-size: 68px; font-weight: 900; letter-spacing: -0.035em; line-height: 1.1;
      color: var(--c-text); margin-bottom: 20px;
    }
    .hero h1 .big-num {
      display: inline-block; color: var(--c-primary); font-feature-settings: var(--tx-mono);
    }
    .hero p.hero-sub {
      font-size: 18px; color: var(--c-text-2); font-weight: 500;
      margin-bottom: 40px; line-height: 1.55;
    }
    .hero-stats { display: flex; gap: 48px; margin-bottom: 40px; flex-wrap: wrap; }
    .hero-stat { }
    .hero-stat-label { font-size: 12px; color: var(--c-text-3); font-weight: 600; margin-bottom: 6px; }
    .hero-stat-num { font-size: 28px; font-weight: 800; letter-spacing: -0.02em; color: var(--c-text); font-feature-settings: var(--tx-mono); }

    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

    /* Right: featured card (live event) */
    .hero-feature {
      background: var(--c-navy);
      color: #fff;
      border-radius: var(--r-xl);
      padding: 40px;
      position: relative;
      overflow: hidden;
    }
    .hero-feature::before {
      content: ''; position: absolute; top: -40px; right: -40px;
      width: 200px; height: 200px; border-radius: 50%;
      background: radial-gradient(circle, rgba(49,130,246,0.35) 0%, transparent 70%);
    }
    .hero-feature-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
      background: rgba(255,255,255,0.1); color: #fff;
      padding: 6px 12px; border-radius: var(--r-pill); margin-bottom: 20px;
    }
    .hero-feature-tag .pulse { width: 6px; height: 6px; border-radius: 50%; background: var(--c-danger); animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
    .hero-feature-name { font-size: 36px; font-weight: 900; letter-spacing: -0.025em; margin-bottom: 6px; line-height: 1.15; }
    .hero-feature-sub { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
    .hero-feature-kpi { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
    .hero-feature-kpi .fk-label { font-size: 12px; color: rgba(255,255,255,0.6); font-weight: 600; margin-bottom: 8px; }
    .hero-feature-kpi .fk-num {
      font-size: 38px; font-weight: 900; letter-spacing: -0.03em; line-height: 1;
      font-feature-settings: var(--tx-mono);
    }
    .hero-feature-kpi .fk-num .t { font-size: 14px; color: rgba(255,255,255,0.5); font-weight: 600; margin-left: 6px; }
    .hero-feature-kpi .fk-rate { font-size: 13px; font-weight: 700; margin-top: 8px; color: var(--c-success); }
    .hero-feature-progress { height: 4px; background: rgba(255,255,255,0.15); border-radius: 2px; overflow: hidden; margin-top: 12px; }
    .hero-feature-progress .bar { height: 100%; background: var(--c-success); border-radius: 2px; transition: width 0.6s ease; }
    .hero-feature-link {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 14px; font-weight: 700; color: #fff;
      padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.12);
      width: 100%; justify-content: space-between;
    }
    .hero-feature-link:hover { color: var(--c-primary-bg); }

    /* ────────────────────────────────────────────────
       Buttons
    ──────────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      padding: 16px 28px; border-radius: var(--r-md); font-size: 15px; font-weight: 700;
      border: none; transition: background 0.12s, color 0.12s, transform 0.12s;
      letter-spacing: -0.01em; height: 54px;
    }
    .btn-primary { background: var(--c-primary); color: #fff; }
    .btn-primary:hover { background: var(--c-primary-hover); }
    .btn-ghost { background: var(--c-surface-deep); color: var(--c-text); }
    .btn-ghost:hover { background: var(--c-border-strong); }
    .btn-lg { padding: 18px 32px; font-size: 16px; height: 58px; }
    .btn-sm { padding: 10px 16px; font-size: 13px; height: 40px; }

    /* ────────────────────────────────────────────────
       Section
    ──────────────────────────────────────────────── */
    section.section { padding: 120px 0; }
    section.section.alt { background: var(--c-surface-alt); }
    .section-head { margin-bottom: 56px; max-width: 720px; }
    .section-eyebrow {
      font-size: 13px; font-weight: 700; color: var(--c-primary);
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 14px;
    }
    .section-head h2 {
      font-size: 44px; font-weight: 900; letter-spacing: -0.025em;
      line-height: 1.2; color: var(--c-text); margin-bottom: 16px;
    }
    .section-head p {
      font-size: 17px; color: var(--c-text-2); font-weight: 500; line-height: 1.6;
    }

    /* ────────────────────────────────────────────────
       Event Cards (large magazine-like)
    ──────────────────────────────────────────────── */
    .card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .card-grid.triple { grid-template-columns: repeat(3, 1fr); }

    .ev-card {
      background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-xl);
      padding: 36px 36px 32px; transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      text-decoration: none; color: var(--c-text); display: flex; flex-direction: column;
      position: relative; overflow: hidden;
    }
    .ev-card:hover { transform: translateY(-4px); box-shadow: var(--sh-3); border-color: transparent; }
    .ev-card-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700; padding: 5px 12px; border-radius: var(--r-pill);
      letter-spacing: 0.04em; align-self: flex-start; margin-bottom: 16px;
    }
    .ev-card-tag.live { background: var(--c-danger-bg); color: var(--c-danger); }
    .ev-card-tag.done { background: var(--c-border); color: var(--c-text-3); }
    .ev-card-tag.soon { background: var(--c-primary-bg); color: var(--c-primary); }
    .ev-card-tag.archive { background: var(--c-warning-bg); color: var(--c-warning); }
    .ev-card-tag .pulse { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: pulse 1.5s infinite; }
    .ev-card-title { font-size: 24px; font-weight: 800; letter-spacing: -0.02em; line-height: 1.25; margin-bottom: 6px; }
    .ev-card-desc { font-size: 13px; color: var(--c-text-3); font-weight: 500; margin-bottom: 28px; line-height: 1.5; }
    .ev-card-kpi { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding-top: 20px; border-top: 1px solid var(--c-border); }
    .ev-card-kpi > div { }
    .ev-card-kpi-label { font-size: 11px; color: var(--c-text-3); font-weight: 600; margin-bottom: 4px; letter-spacing: 0.02em; }
    .ev-card-kpi-num { font-size: 20px; font-weight: 800; letter-spacing: -0.02em; color: var(--c-text); font-feature-settings: var(--tx-mono); }
    .ev-card-kpi-num.success { color: var(--c-success); }
    .ev-card-kpi-num.warning { color: var(--c-warning); }
    .ev-card-kpi-num.danger { color: var(--c-danger); }
    .ev-card-link { margin-top: 20px; font-size: 13px; color: var(--c-primary); font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }

    /* Big CTA card (for WORK FEST countdown, etc.) */
    .cta-card {
      background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-deep) 100%);
      color: #fff;
      border-radius: var(--r-xl);
      padding: 56px 48px;
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 32px;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .cta-card::before {
      content: ''; position: absolute; right: -80px; bottom: -80px;
      width: 300px; height: 300px; border-radius: 50%;
      background: rgba(255,255,255,0.08);
    }
    .cta-card-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.85; margin-bottom: 12px; }
    .cta-card h3 { font-size: 36px; font-weight: 900; letter-spacing: -0.025em; line-height: 1.2; margin-bottom: 10px; }
    .cta-card p { font-size: 15px; opacity: 0.85; line-height: 1.55; margin-bottom: 24px; }
    .cta-card-stats { display: flex; gap: 32px; flex-wrap: wrap; }
    .cta-card-stat { }
    .cta-card-stat-label { font-size: 12px; opacity: 0.7; font-weight: 600; margin-bottom: 4px; }
    .cta-card-stat-num { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; font-feature-settings: var(--tx-mono); }
    .cta-card-side {
      position: relative; z-index: 1;
      text-align: center; padding: 32px 20px;
      background: rgba(255,255,255,0.1); border-radius: var(--r-lg);
      backdrop-filter: blur(10px);
    }
    .cta-card-dday { font-size: 72px; font-weight: 900; letter-spacing: -0.04em; line-height: 1; font-feature-settings: var(--tx-mono); }
    .cta-card-dday-sub { font-size: 13px; opacity: 0.85; font-weight: 600; margin-top: 4px; }

    /* Archive (2025) cards - subtle */
    .archive-card {
      background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg);
      padding: 28px 32px; display: flex; align-items: center; gap: 24px; justify-content: space-between;
      transition: border-color 0.15s, background 0.15s;
    }
    .archive-card:hover { border-color: var(--c-border-strong); background: var(--c-surface-alt); }
    .archive-card .ac-main { display: flex; align-items: center; gap: 16px; flex: 1; min-width: 0; }
    .archive-card .ac-date { font-size: 12px; color: var(--c-text-4); font-weight: 600; font-feature-settings: var(--tx-mono); min-width: 60px; }
    .archive-card .ac-body { min-width: 0; }
    .archive-card .ac-name { font-size: 17px; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 2px; }
    .archive-card .ac-desc { font-size: 12px; color: var(--c-text-3); font-weight: 500; }
    .archive-card .ac-stats { display: flex; gap: 28px; font-feature-settings: var(--tx-mono); }
    .archive-card .ac-stats .stat { text-align: right; }
    .archive-card .ac-stats .stat .num { font-size: 16px; font-weight: 800; letter-spacing: -0.01em; }
    .archive-card .ac-stats .stat .num.success { color: var(--c-success); }
    .archive-card .ac-stats .stat .num.warning { color: var(--c-warning); }
    .archive-card .ac-stats .stat .num.danger { color: var(--c-danger); }
    .archive-card .ac-stats .stat .label { font-size: 10px; color: var(--c-text-4); font-weight: 600; margin-top: 2px; }

    /* Empty state (아티클 준비 중) */
    .empty-state {
      background: var(--c-surface-alt); border: 1px dashed var(--c-border-strong); border-radius: var(--r-xl);
      padding: 80px 32px; text-align: center;
    }
    .empty-state .es-emoji { font-size: 32px; margin-bottom: 16px; }
    .empty-state .es-title { font-size: 20px; font-weight: 800; margin-bottom: 8px; }
    .empty-state .es-sub { font-size: 14px; color: var(--c-text-3); font-weight: 500; }

    /* ────────────────────────────────────────────────
       Summary strip (for quick KPI scanning)
    ──────────────────────────────────────────────── */
    .kpi-strip {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
      padding: 32px; background: var(--c-surface); border: 1px solid var(--c-border);
      border-radius: var(--r-xl); margin-top: -48px; position: relative; z-index: 2;
      box-shadow: var(--sh-2);
    }
    .kpi-strip .km { }
    .kpi-strip .km-label { font-size: 13px; color: var(--c-text-3); font-weight: 600; margin-bottom: 10px; }
    .kpi-strip .km-num { font-size: 30px; font-weight: 800; letter-spacing: -0.025em; line-height: 1.1; color: var(--c-text); font-feature-settings: var(--tx-mono); }
    .kpi-strip .km-sub { font-size: 12px; color: var(--c-text-4); font-weight: 500; margin-top: 6px; }
    .kpi-strip .km-sub a { color: var(--c-primary); font-weight: 600; }

    /* ────────────────────────────────────────────────
       Footer
    ──────────────────────────────────────────────── */
    footer {
      padding: 48px 0; border-top: 1px solid var(--c-border);
      font-size: 13px; color: var(--c-text-3); font-weight: 500;
    }
    footer .container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    footer a { color: var(--c-primary); font-weight: 600; }

    /* ────────────────────────────────────────────────
       AI FAB (floating)
    ──────────────────────────────────────────────── */
    #ai-fab {
      position: fixed; bottom: 28px; right: 28px;
      width: 60px; height: 60px; border-radius: 50%;
      background: var(--c-primary); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; cursor: pointer;
      box-shadow: 0 8px 24px rgba(49,130,246,0.35);
      z-index: 99; transition: transform 0.15s, box-shadow 0.15s;
    }
    #ai-fab:hover { transform: scale(1.08); box-shadow: 0 12px 32px rgba(49,130,246,0.45); }
    #ai-panel {
      position: fixed; bottom: 100px; right: 28px;
      width: 400px; max-width: calc(100vw - 56px);
      background: #fff; border-radius: var(--r-xl);
      box-shadow: var(--sh-3);
      z-index: 99; overflow: hidden; display: none; flex-direction: column;
      max-height: 560px; border: 1px solid var(--c-border);
    }
    #ai-panel.is-open { display: flex; }
    #ai-panel-head {
      padding: 20px; background: var(--c-navy); color: #fff;
      display: flex; align-items: center; justify-content: space-between;
    }
    #ai-panel-head .t { font-weight: 800; font-size: 15px; }
    #ai-panel-head .s { font-size: 11px; opacity: 0.7; font-weight: 500; margin-top: 2px; }
    #ai-panel-head button { background: none; border: none; color: #fff; font-size: 18px; cursor: pointer; padding: 4px; }
    #ai-msgs { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 10px; min-height: 240px; }
    #ai-msgs .msg { padding: 12px 16px; border-radius: 14px; font-size: 13px; line-height: 1.55; max-width: 85%; user-select: text; }
    #ai-msgs .msg.bot { background: var(--c-surface-alt); color: var(--c-text); align-self: flex-start; }
    #ai-msgs .msg.user { background: var(--c-primary); color: #fff; align-self: flex-end; font-weight: 500; }
    .ai-chips { display: flex; flex-wrap: wrap; gap: 6px; align-self: flex-start; }
    .ai-chip {
      padding: 8px 14px; border-radius: var(--r-pill); border: 1px solid var(--c-border-strong);
      background: var(--c-surface); font-size: 12px; font-family: inherit; font-weight: 600;
      color: var(--c-text-2); cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s;
    }
    .ai-chip:hover, .ai-chip.primary { background: var(--c-primary-bg); border-color: var(--c-primary); color: var(--c-primary); }
    .ai-chip.primary { background: var(--c-primary); color: #fff; border-color: var(--c-primary); }
    #ai-input-row { padding: 14px 16px; border-top: 1px solid var(--c-border); display: flex; gap: 8px; }
    #ai-input { flex: 1; padding: 12px 14px; border: 1px solid var(--c-border-strong); border-radius: 12px; font-size: 13px; font-family: inherit; outline: none; transition: border-color 0.12s; }
    #ai-input:focus { border-color: var(--c-primary); }
    #ai-send { padding: 12px 18px; border-radius: 12px; border: none; background: var(--c-primary); color: #fff; font-size: 13px; font-weight: 700; cursor: pointer; }

    /* ────────────────────────────────────────────────
       Responsive
    ──────────────────────────────────────────────── */
    @media (max-width: 960px) {
      .hero-grid { grid-template-columns: 1fr; gap: 40px; }
      .hero h1 { font-size: 52px; }
      .card-grid, .card-grid.triple { grid-template-columns: 1fr; }
      .kpi-strip { grid-template-columns: 1fr 1fr; }
      .cta-card { grid-template-columns: 1fr; text-align: left; }
      .cta-card-side { text-align: center; }
      .nav-menu { display: none; }
    }
    @media (max-width: 640px) {
      .container { padding: 0 20px; }
      .hero { padding: calc(var(--nav-h) + 48px) 0 56px; }
      .hero h1 { font-size: 40px; }
      .section-head h2 { font-size: 32px; }
      section.section { padding: 72px 0; }
      .hero-feature { padding: 28px; }
      .hero-feature-name { font-size: 28px; }
      .hero-feature-kpi .fk-num { font-size: 30px; }
      .archive-card { flex-direction: column; align-items: flex-start; gap: 16px; }
      .archive-card .ac-stats { width: 100%; justify-content: space-between; gap: 12px; }
      .cta-card { padding: 36px 28px; }
      .cta-card h3 { font-size: 28px; }
      .cta-card-dday { font-size: 56px; }
      .kpi-strip { margin-top: 0; box-shadow: none; border-radius: var(--r-lg); padding: 20px; }
      .kpi-strip .km-num { font-size: 22px; }
    }
  </style>
</head>
<body>
  <!-- ════════════════════════════════════════════════
       Top Nav
  ════════════════════════════════════════════════ -->
  <nav class="nav" id="topnav">
    <div class="nav-inner">
      <a class="nav-brand" href="#top"><span class="dot"></span>인사이트전략팀</a>
