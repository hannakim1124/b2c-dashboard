<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>데브콘 성과 대시보드</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css">
  <style>
    /* === Toss-style Design Tokens === */
    :root {
      --c-bg: #FFFFFF;
      --c-surface: #FFFFFF;
      --c-surface-alt: #F9FAFB;
      --c-border: #F2F4F6;
      --c-border-strong: #E5E8EB;
      --c-text: #191F28;
      --c-text-2: #4E5968;
      --c-text-3: #8B95A1;
      --c-text-4: #B0B8C1;
      --c-primary: #3182F6;
      --c-primary-bg: #E8F3FF;
      --c-primary-strong: #1B64DA;
      --c-success: #00C896;
      --c-success-bg: #E5F9F4;
      --c-warning: #FFB700;
      --c-warning-bg: #FFF7E0;
      --c-danger: #F04452;
      --c-danger-bg: #FFEBEC;

      --r-sm: 8px; --r-md: 12px; --r-lg: 16px; --r-xl: 20px; --r-pill: 999px;
      --sh-1: 0 1px 2px rgba(15,19,36,0.04);
      --tx-mono-feature: "tnum" on, "lnum" on;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Pretendard', -apple-system, sans-serif; background: var(--c-bg); color: var(--c-text); padding: 56px 32px 80px; -webkit-font-smoothing: antialiased; max-width: 1280px; margin: 0 auto; }

    .back-link { display: inline-flex; align-items: center; gap: 6px; text-decoration: none; color: var(--c-text-3); font-size: 13px; font-weight: 600; margin-bottom: 28px; transition: color 0.12s; }
    .back-link:hover { color: var(--c-text); }

    .page-header { text-align: left; margin-bottom: 48px; }
    .page-header .badge { display: inline-block; font-size: 11px; padding: 5px 12px; border-radius: var(--r-pill); background: var(--c-primary-bg); color: var(--c-primary); font-weight: 700; margin-bottom: 12px; letter-spacing: 0.04em; }
    h1 { text-align: left; margin-bottom: 8px; font-size: 34px; font-weight: 800; color: var(--c-text); letter-spacing: -0.025em; line-height: 1.15; }
    .subtitle { text-align: left; color: var(--c-text-3); font-size: 14px; font-weight: 500; margin-bottom: 8px; }
    .data-badge { display: none; font-size: 11px; padding: 4px 10px; border-radius: var(--r-pill); font-weight: 700; letter-spacing: 0.02em; }

    /* === Card system === */
    .card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 28px 24px; text-align: left; min-width: 150px; transition: border-color 0.12s; }
    .card:hover { border-color: var(--c-border-strong); }
    .card .label { font-size: 13px; color: var(--c-text-3); margin-bottom: 14px; font-weight: 600; display: flex; align-items: center; gap: 6px; }
    .card .number { font-size: 32px; font-weight: 800; color: var(--c-text); letter-spacing: -0.025em; line-height: 1.1; font-feature-settings: var(--tx-mono-feature); }
    .card .sub { font-size: 12px; color: var(--c-text-4); margin-top: 8px; font-weight: 500; line-height: 1.5; }

    /* Mini KPI card — 광고 효율, GA 등 */
    .stat-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 24px; transition: border-color 0.12s; }
    .stat-card:hover { border-color: var(--c-border-strong); }
    .stat-card .stat-label { font-size: 13px; color: var(--c-text-3); font-weight: 600; }
    .stat-card .stat-num { font-size: 28px; font-weight: 800; color: var(--c-text); margin-top: 10px; letter-spacing: -0.025em; line-height: 1.1; font-feature-settings: var(--tx-mono-feature); }
    .stat-card .stat-num.success { color: var(--c-success); }
    .stat-card .stat-num.danger { color: var(--c-danger); }
    .stat-card .stat-sub { font-size: 12px; color: var(--c-text-4); margin-top: 8px; font-weight: 500; line-height: 1.5; }

    /* === Section === */
    .ga-section { margin: 0 auto 40px; }
    .ga-section h2 { font-size: 20px; margin-bottom: 16px; font-weight: 800; color: var(--c-text); letter-spacing: -0.02em; }
    .ga-section .section-meta { font-size: 12px; color: var(--c-text-4); margin-bottom: 16px; font-weight: 500; }

    /* === Tables === */
    .ga-table { width: 100%; border-collapse: collapse; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); overflow: hidden; }
    .ga-table th { text-align: left; padding: 14px 18px; font-size: 12px; color: var(--c-text-3); border-bottom: 1px solid var(--c-border); background: var(--c-surface-alt); font-weight: 600; letter-spacing: 0.02em; }
    .ga-table td { padding: 14px 18px; font-size: 13px; border-bottom: 1px solid var(--c-border); color: var(--c-text); font-feature-settings: var(--tx-mono-feature); }
    .ga-table tr:last-child td { border-bottom: none; }
    .ga-table tr:hover td { background: var(--c-surface-alt); }
    .ga-note { font-size: 12px; color: var(--c-text-4); margin-top: 10px; line-height: 1.5; font-weight: 500; }

    /* === Charts === */
    .charts { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 0 auto 40px; overflow: hidden; }
    .chart-box { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 24px; overflow: hidden; min-width: 0; transition: border-color 0.12s; }
    .chart-box:hover { border-color: var(--c-border-strong); }
    .chart-box h3 { margin-bottom: 14px; font-size: 15px; color: var(--c-text); font-weight: 700; letter-spacing: -0.01em; }
    .chart-box canvas { max-height: 240px; max-width: 100%; }
    .chart-box.full { grid-column: 1 / -1; }

    /* === Feedback === */
    .feedback { margin: 0 auto 40px; }
    .feedback h2 { font-size: 20px; margin-bottom: 16px; font-weight: 800; color: var(--c-text); letter-spacing: -0.02em; }
    .feedback-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .feedback-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 28px; }
    .feedback-card h3 { font-size: 15px; color: var(--c-text); margin-bottom: 16px; font-weight: 700; }

    /* === Note box === */
    .note-box { background: var(--c-warning-bg); border: 1px solid #FFE89A; border-radius: var(--r-lg); padding: 16px 20px; font-size: 12px; color: #8C6500; margin: 0 auto 40px; line-height: 1.6; font-weight: 500; }
    .pending { color: var(--c-text-4); font-weight: 500; }

    /* === Insight panel === */
    .insight-panel { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 28px 32px; margin-bottom: 40px; }
    .insight-panel h2 { font-size: 18px; margin-bottom: 20px; color: var(--c-text); font-weight: 800; letter-spacing: -0.02em; }
    .insight-panel .insight-content { line-height: 1.8; font-size: 13px; color: var(--c-text); font-weight: 500; }
    .insight-panel .insight-content b { color: var(--c-text); font-weight: 700; }

    /* === KPI Cards === */
    .kpi-cards { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin: 0 auto 40px; }

    /* === Review chips === */
    .review-chip { display: inline-block; padding: 8px 14px; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-sm); font-size: 12px; color: var(--c-text); text-decoration: none; font-weight: 500; transition: background 0.12s, border-color 0.12s; }
    .review-chip:hover { background: var(--c-surface-alt); border-color: var(--c-border-strong); }

    @media (max-width: 1024px) {
      .kpi-cards { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 768px) {
      body { padding: 32px 20px 60px; }
      h1 { font-size: 24px; }
      .charts { grid-template-columns: 1fr; }
      .feedback-grid { grid-template-columns: 1fr; }
      .ga-table { font-size: 11px; }
      .ga-table th, .ga-table td { padding: 12px; }
      .kpi-cards { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      body { padding: 24px 14px 60px; font-size: 14px; }
      h1 { font-size: 22px; }
      .subtitle { font-size: 12px; }
      .card { padding: 20px 16px; min-width: 0; }
      .card .number { font-size: 24px; }
      .card .label { font-size: 12px; margin-bottom: 10px; }
      .card .sub { font-size: 11px; }
      .stat-card { padding: 18px 16px; }
      .stat-card .stat-num { font-size: 22px; }
      .ga-section { overflow: hidden; }
      .ga-section h2 { font-size: 17px; }
      .ga-table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .ga-table th, .ga-table td { min-width: 80px; white-space: nowrap; padding: 10px 8px; font-size: 11px; }
      .chart-box { padding: 18px; }
      .chart-box h3 { font-size: 14px; }
      .chart-box canvas { max-height: 200px; }
      .charts { gap: 12px; }
      .insight-panel { padding: 22px 18px; }
      .resp-grid-3 { grid-template-columns: 1fr !important; }
      .resp-grid-4 { grid-template-columns: 1fr 1fr !important; }
    }
  </style>
</head>
<body>
  <a href="./index.html" class="back-link">← B2C 대시보드</a>
  <div class="page-header">
    <span class="badge">웨비나</span>
    <h1>JOBKOREA DEVCON</h1>
