  </div>

  <!-- 예산 및 단가 분석 -->
  <div class="ga-section">
    <h2>예산 및 단가 분석</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px" class="resp-grid-3">
      <div class="stat-card">
        <div class="stat-label">광고 집행액 (최종)</div>
        <div class="stat-num">4,498,434원</div>
