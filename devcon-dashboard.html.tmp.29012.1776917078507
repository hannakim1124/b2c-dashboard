      </div>
    </div>
    <table class="ga-table">
      <thead>
        <tr><th>항목</th><th>품의 금액</th><th>실제 집행액</th><th>차이</th><th>비고</th></tr>
      </thead>
      <tbody>
        <tr><td>광고비(Meta)</td><td style="text-align:right">4,500,000</td><td style="text-align:right">4,498,434</td><td style="text-align:right;color:#00c48c">-1,566</td><td>4/21 최종 (99.97% 집행)</td></tr>
        <tr><td>연사료</td><td style="text-align:right">1,000,000</td><td style="text-align:right" class="pending">—</td><td style="text-align:right" class="pending">—</td><td>계약 후 지급 예정</td></tr>
        <tr><td>경품비</td><td style="text-align:right">500,000</td><td style="text-align:right" class="pending">—</td><td style="text-align:right" class="pending">—</td><td>이벤트 종료 후</td></tr>
        <tr style="background:#e8f3ff;font-weight:700"><td>합계</td><td style="text-align:right">6,000,000</td><td style="text-align:right">4,498,434</td><td style="text-align:right;color:#00c48c">-1,501,566</td><td>연사료·경품 정산 대기</td></tr>
      </tbody>
