    <div id="insightContent" class="insight-content">데이터 로딩 중...</div>
  </div>

  <!-- 핵심 지표 -->
  <div class="kpi-cards">
    <div class="card"><div class="label">신청자 KPI</div><div class="number" id="kpiPct">—</div><div class="sub" id="kpiSub">로딩 중...</div></div>
