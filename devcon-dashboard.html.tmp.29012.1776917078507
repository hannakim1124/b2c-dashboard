      srcTop: [["광고(SNS)",762],["지인 추천",231],["잡플래닛 이메일",108],["잡코리아 상단 배너",97],["연사 SNS(인스타, 스레드, 오카방 등)",68],["잡코리아 팝업 메시지",60],["잡코리아 홈페이지(공지사항 및 콘텐츠LAB)",42],["게임잡 팝업 메시지",40],["잡코리아 인스타그램",39],["커리어 컨퍼런스에서 알게 됨",12]],
