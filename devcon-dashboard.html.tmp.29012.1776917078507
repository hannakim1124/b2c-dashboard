    // === 구글 시트에서 실시간 데이터 파싱 ===
    function processSheetData(rows) {
      const dataRows = rows.slice(1).filter(r => r.length > 6 && r[0]);

      // 전체 (중복 포함)
      const unique = dataRows;
      const total = dataRows.length;

      // 핸드폰 번호(col 6) 기준 유니크 수 (하단 표시용)
      const seen = new Set();
      dataRows.forEach(r => {
        const phone = digitsOnly(r[6]);
        if (phone && phone.length >= 10) seen.add(phone);
      });
      const uniqueTotal = seen.size;
      const now = new Date();
      const todayStr = now.getFullYear() + '/' + (now.getMonth() + 1) + '/' + now.getDate();
      const yd = new Date(now); yd.setDate(yd.getDate() - 1);
      const ydStr = yd.getFullYear() + '/' + (yd.getMonth() + 1) + '/' + yd.getDate();

      function parseTS(tsStr) {
        // 타임스탬프: "2026/4/1 12:34:56" or "2026. 4. 1 오후 12:34:56"
        const d = new Date(tsStr.replace(/\./g, '/').replace(/오[전후]\s*/g, ''));
        return isNaN(d) ? null : d;
      }
      function dateKey(d) { return d.getFullYear() + '/' + (d.getMonth() + 1) + '/' + d.getDate(); }

      let todayN = 0, ydN = 0;
      unique.forEach(r => {
        const d = parseTS(r[0]);
        if (!d) return;
        const dk = dateKey(d);
        if (dk === todayStr) todayN++;
        if (dk === ydStr) ydN++;
      });

      const resume = unique.filter(r => r[10] && r[10].trim()).length;
      // 유효 ID(4자 이상 + 영숫자 포함, 한글만/단어 아님) + 중복 제거
      function isValidId(x) { x = (x||'').trim(); if (x.length < 4) return false; if (/^[가-힣\s]+$/.test(x)) return false; if (!/[a-zA-Z0-9]/.test(x)) return false; return true; }
      const resumeIdSet = new Set();
      unique.forEach(r => { const v = (r[10]||'').trim(); if (isValidId(v)) resumeIdSet.add(v.toLowerCase()); });
      const resumeVerified = resumeIdSet.size;
      const sns = unique.filter(r => r[11] && /https?:\/\//i.test(r[11].trim())).length;

      let eventPart = 0, confOnly = 0;
      unique.forEach(r => {
        if ((r[1] || '').includes('이벤트도 참여')) eventPart++;
        else confOnly++;
      });

      // 일별 분포
      const dailyMap = {};
      unique.forEach(r => {
        const d = parseTS(r[0]);
        if (!d) return;
        const key = String(d.getMonth() + 1).padStart(2, '0') + '/' + String(d.getDate()).padStart(2, '0');
        dailyMap[key] = (dailyMap[key] || 0) + 1;
      });

      // 신청 경로 (col 8)
      const channelMap = {};
      unique.forEach(r => { const ch = (r[8] || '').trim(); if (ch) channelMap[ch] = (channelMap[ch] || 0) + 1; });
      const srcTop = Object.entries(channelMap).sort((a, b) => b[1] - a[1]).slice(0, 10);

      // 연차별 (col 4)
      const yearBuckets = { '0년차\n(대학생/취준)': 0, '1~3년차': 0, '4~6년차': 0, '7~9년차': 0, '10년차 이상': 0 };
      const yearRules = [
        [/대학|취준|0년|학생/i, '0년차\n(대학생/취준)'],
        [/1.?3년|1년|2년|3년/i, '1~3년차'],
        [/4.?6년|4년|5년|6년/i, '4~6년차'],
        [/7.?9년|7년|8년|9년/i, '7~9년차'],
        [/10년|11년|12년|15년|20년|이상/i, '10년차 이상']
      ];
      unique.forEach(r => {
        const yr = (r[4] || '').trim();
        for (const [re, key] of yearRules) { if (re.test(yr)) { yearBuckets[key]++; break; } }
      });

      // 직무별 (col 5)
      const jobMap = {};
      unique.forEach(r => { const job = (r[5] || '').trim(); if (job) jobMap[job] = (jobMap[job] || 0) + 1; });
      const jobSorted = Object.entries(jobMap).sort((a, b) => b[1] - a[1]).slice(0, 10);

      const pad = n => String(n).padStart(2, '0');
      const updateTime = (now.getMonth() + 1) + '/' + now.getDate() + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes());

      return {
        total, uniqueTotal, todayN, ydN, resume, resumeVerified, sns,
        eventPart, confOnly, updateTime,
        dailyMap, srcTop,
        yearLabels: Object.keys(yearBuckets),
        yearData: Object.values(yearBuckets),
        jobSorted, isLive: true
      };
    }

