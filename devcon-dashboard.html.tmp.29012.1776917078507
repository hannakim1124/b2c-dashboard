  </div>

  <!-- 줌 라이브 참여 -->
  <div class="ga-section">
    <h2>줌 라이브 참여</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
      <div class="stat-card">
        <div class="stat-label">실참석자 (유니크)</div>
        <div class="stat-num" style="color:var(--c-text-4);letter-spacing:2px;font-size:22px">COMING SOON</div>
