    function doughnutOpts(pos) {
      return { responsive: true, plugins: { legend: { position: pos || 'right', labels: { font: { size: 11 } } }, datalabels: { display: true, color: '#191f28', font: { size: 11, weight: 'bold' }, formatter: (v, ctx) => { const t = ctx.dataset.data.reduce((a,b)=>a+b,0); const p = (v/t*100).toFixed(1); return p < 5 ? '' : ctx.chart.data.labels[ctx.dataIndex]+'\n'+p+'%'; }, textAlign: 'center' } } };
    }

    // === CSV 파싱 유틸 ===
    function parseCSV(text) {
      const rows = [];
      let current = '', inQuote = false, row = [], i = 0;
      while (i < text.length) {
        const ch = text[i];
        if (inQuote) {
          if (ch === '"' && text[i + 1] === '"') { current += '"'; i += 2; }
          else if (ch === '"') { inQuote = false; i++; }
          else { current += ch; i++; }
        } else {
          if (ch === '"') { inQuote = true; i++; }
          else if (ch === ',') { row.push(current.trim()); current = ''; i++; }
          else if (ch === '\n' || ch === '\r') {
            row.push(current.trim()); current = '';
            if (row.length > 1 || row[0] !== '') rows.push(row);
            row = [];
            if (ch === '\r' && text[i + 1] === '\n') i++;
            i++;
          } else { current += ch; i++; }
        }
      }
      row.push(current.trim());
      if (row.length > 1 || row[0] !== '') rows.push(row);
      return rows;
    }

    function digitsOnly(str) { return (str || '').replace(/[^0-9]/g, ''); }

    // === 정적 데이터 (폴백용, 4/22 기준) ===
    const STATIC_DATA = {
