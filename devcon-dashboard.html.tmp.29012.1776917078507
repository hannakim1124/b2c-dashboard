      new Chart(document.getElementById('jobChart'), {
        type: 'doughnut',
        data: { labels: jobSorted.map(s=>s[0]), datasets: [{ data: jobSorted.map(s=>s[1]), backgroundColor: pastel }] },
        options: doughnutOpts()
      });

      // 신청 유형
      new Chart(document.getElementById('eventTypeChart'), {
        type: 'doughnut',
        data: { labels: ['컨퍼런스 + 이벤트 참여 ('+eventPart+'명)', '컨퍼런스만 ('+confOnly+'명)'], datasets: [{ data: [eventPart, confOnly], backgroundColor: ['#ff9500', '#3182f6'] }] },
        options: { responsive: true, plugins: { legend: { position: 'bottom' }, datalabels: { display: true, color: '#191f28', font: { size: 13, weight: 'bold' }, formatter: (v, ctx) => { const t = ctx.dataset.data.reduce((a,b)=>a+b,0); return (v/t*100).toFixed(1)+'%'; } } } }
      });
    }

    // === 페이지 로드 시 API fetch + 폴백 ===
    (async function() {
      try {
        // Vercel API route (서버에서 구글 시트 가져옴 → CORS/프록시 문제 없음)
        const API_URL = window.location.hostname === 'localhost' || window.location.protocol === 'file:'
          ? 'https://b2c-dashboard-sigma.vercel.app/api/devcon-data'
          : '/api/devcon-data';
        const res = await fetch(API_URL);
        if (!res.ok) throw new Error('API ' + res.status);
        const liveData = await res.json();
        if (liveData.error) throw new Error(liveData.error);
        renderDashboard(liveData);
        console.log('[DEVCON] API 데이터 로드 완료:', liveData.total + '명');
      } catch (err) {
        console.warn('[DEVCON] API fetch 실패, 정적 데이터 사용:', err);
        renderDashboard(STATIC_DATA);
      }
    })();
  </script>
</body>
</html>
