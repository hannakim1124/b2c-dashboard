<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>인사이트전략팀 B2C 대시보드</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css">
  <style>
    /* === Toss-style Design Tokens === */
    :root {
      --c-bg: #FFFFFF;
      --c-surface: #FFFFFF;
      --c-surface-alt: #F9FAFB;
      --c-border: #F2F4F6;
      --c-border-strong: #E5E8EB;
      --c-text: #191F28;
      --c-text-2: #4E5968;
      --c-text-3: #8B95A1;
      --c-text-4: #B0B8C1;
      --c-primary: #3182F6;
      --c-primary-bg: #E8F3FF;
      --c-primary-strong: #1B64DA;
      --c-success: #00C896;
      --c-success-bg: #E5F9F4;
      --c-warning: #FFB700;
      --c-warning-bg: #FFF7E0;
      --c-danger: #F04452;
      --c-danger-bg: #FFEBEC;

      --r-sm: 8px; --r-md: 12px; --r-lg: 16px; --r-xl: 20px; --r-pill: 999px;
      --sh-1: 0 1px 2px rgba(15,19,36,0.04);
      --sh-2: 0 4px 12px rgba(15,19,36,0.06);
      --sh-3: 0 8px 24px rgba(15,19,36,0.08);
      --tx-mono-feature: "tnum" on, "lnum" on;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Pretendard', -apple-system, sans-serif; background: var(--c-bg); color: var(--c-text); padding: 56px 24px 80px; min-height: 100vh; -webkit-font-smoothing: antialiased; }

    h1 { text-align: left; font-size: 32px; margin-bottom: 4px; font-weight: 800; color: var(--c-text); letter-spacing: -0.02em; line-height: 1.2; }
    .subtitle { text-align: left; color: var(--c-text-3); font-size: 14px; margin-bottom: 40px; font-weight: 500; }
    .container { max-width: 1080px; margin: 0 auto; }

    /* === Sticky Header === */
    .sticky-header { position: sticky; top: 0; z-index: 100; background: var(--c-bg); padding: 24px 0 12px; margin: -56px -24px 28px; padding-left: 24px; padding-right: 24px; border-bottom: 1px solid transparent; transition: border-color 0.2s; }
    .sticky-header.is-stuck { border-bottom-color: var(--c-border); }
    .sticky-inner { max-width: 1080px; margin: 0 auto; }

    /* === Summary KPI Cards (Hero) === */
    .summary-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 0 0 16px; }
    .kpi-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 24px 24px 20px; transition: border-color 0.15s, transform 0.15s; cursor: pointer; position: relative; overflow: hidden; }
    .kpi-card:hover { border-color: var(--c-border-strong); }
    .kpi-card .kpi-label { font-size: 13px; color: var(--c-text-3); font-weight: 600; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
    .kpi-card .kpi-num { font-size: 30px; font-weight: 800; color: var(--c-text); letter-spacing: -0.025em; line-height: 1.1; font-feature-settings: var(--tx-mono-feature); }
    .kpi-card .kpi-sub { font-size: 12px; color: var(--c-text-4); margin-top: 6px; font-weight: 500; line-height: 1.4; }
    .kpi-card .kpi-sub a { color: var(--c-primary); text-decoration: none; font-weight: 600; }
    .kpi-card .kpi-sub a:hover { text-decoration: underline; }

    /* === Year tabs / filter buttons === */
    .toolbar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; padding-top: 4px; }
    .toolbar .group { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
    .toolbar .group-label { font-size: 12px; color: var(--c-text-3); font-weight: 600; margin-right: 4px; }
    .filter-btn { font-size: 12px; padding: 7px 14px; border-radius: var(--r-sm); border: 1px solid var(--c-border-strong); background: var(--c-surface); cursor: pointer; color: var(--c-text-2); font-family: inherit; font-weight: 600; transition: background 0.12s, border-color 0.12s, color 0.12s; }
    .filter-btn:hover { background: var(--c-surface-alt); }
    .filter-btn.is-on { background: var(--c-text); color: #fff; border-color: var(--c-text); }
    .year-btn { font-size: 13px; padding: 7px 14px; border-radius: var(--r-sm); border: 1px solid var(--c-border-strong); background: var(--c-surface); cursor: pointer; color: var(--c-text-2); font-family: inherit; font-weight: 700; transition: background 0.12s, color 0.12s, border-color 0.12s; }
    .year-btn:hover { background: var(--c-surface-alt); }
    .year-btn.active { background: var(--c-text); color: #fff; border-color: var(--c-text); }

    /* === Month / Section labels === */
    .month { margin-bottom: 32px; }
    .month-header { font-size: 11px; font-weight: 800; color: var(--c-text-3); letter-spacing: 0.06em; margin-bottom: 12px; padding-left: 4px; text-transform: uppercase; }
    .category-label { font-size: 11px; color: var(--c-text-4); padding-left: 4px; margin-bottom: 6px; margin-top: 12px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }

    /* === Event Row === */
    .row { display: flex; align-items: center; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--r-lg); padding: 18px 24px; margin-bottom: 8px; text-decoration: none; color: var(--c-text); transition: background 0.12s, border-color 0.12s; cursor: pointer; position: relative; }
    .row:hover { background: var(--c-surface-alt); border-color: var(--c-border-strong); }
    .row .tag { display: inline-block; font-size: 11px; padding: 4px 10px; border-radius: var(--r-sm); font-weight: 700; margin-right: 16px; min-width: 60px; text-align: center; letter-spacing: 0.02em; }
    .row .tag.done { background: var(--c-border); color: var(--c-text-3); }
    .row .tag.live { background: var(--c-danger-bg); color: var(--c-danger); }
    .row .tag.soon { background: var(--c-border); color: var(--c-text-3); }
    .row .name { font-weight: 700; font-size: 15px; min-width: 180px; color: var(--c-text); }
    .row .desc { font-size: 12px; color: var(--c-text-3); flex: 1; }
    .row .stats { display: flex; gap: 28px; margin-left: auto; align-items: center; }
    .row .stat { text-align: right; min-width: 60px; }
    .row .stat .num { font-size: 18px; font-weight: 800; color: var(--c-text); letter-spacing: -0.02em; font-feature-settings: var(--tx-mono-feature); }
    .row .stat .num.red { color: var(--c-danger); }
    .row .stat .num.orange { color: var(--c-warning); }
    .row .stat .label { font-size: 11px; color: var(--c-text-4); font-weight: 500; margin-top: 2px; }

    .row.empty { border: 1px dashed var(--c-border-strong); background: var(--c-surface-alt); box-shadow: none; cursor: pointer; justify-content: center; padding: 20px; }
    .row.empty:hover { background: var(--c-bg); border-color: var(--c-primary); }
    .row.empty .placeholder { color: var(--c-text-3); font-size: 13px; font-weight: 600; }
    .row.faded { opacity: 0.55; }
    .dot { position: absolute; top: -3px; left: -5px; width: 6px; height: 6px; background: var(--c-danger); border-radius: 50%; animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.85); } }

    .footer { text-align: center; margin-top: 56px; font-size: 12px; color: var(--c-text-4); font-weight: 500; }
    .cmp-label { display: flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: var(--r-sm); border: 1px solid var(--c-border-strong); cursor: pointer; font-size: 12px; font-weight: 600; color: var(--c-text-2); font-family: inherit; transition: background 0.12s, border-color 0.12s; }
    .cmp-label:hover { background: var(--c-surface-alt); border-color: var(--c-text-3); }
    #compare-table th { text-align: left; padding: 14px 16px; font-size: 12px; color: var(--c-text-3); border-bottom: 1px solid var(--c-border); background: var(--c-surface-alt); font-weight: 600; letter-spacing: 0.02em; }
    #compare-table td { padding: 13px 16px; font-size: 13px; border-bottom: 1px solid var(--c-border); color: var(--c-text); text-align: right; font-feature-settings: var(--tx-mono-feature); }
    #compare-table td:first-child { text-align: left; font-weight: 600; color: var(--c-text-2); }
    #compare-table tr:last-child td { border-bottom: none; }
    #compare-table tr:hover td { background: var(--c-surface-alt); }
    .ai-chip { padding: 8px 14px; border-radius: var(--r-pill); border: 1px solid var(--c-border-strong); background: var(--c-surface); font-size: 12px; font-family: inherit; font-weight: 600; color: var(--c-text-2); cursor: pointer; transition: background 0.12s, border-color 0.12s, color 0.12s; }
    .ai-chip:hover { background: var(--c-primary-bg); border-color: var(--c-primary); color: var(--c-primary); }

    @media (max-width: 900px) {
      .summary-cards { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      body { padding: 32px 16px 60px; }
      h1 { font-size: 24px; }
      .sticky-header { margin-left: -16px; margin-right: -16px; padding-left: 16px; padding-right: 16px; }
      .row { flex-wrap: wrap; padding: 16px; gap: 8px; }
      .row .name { min-width: auto; font-size: 14px; }
      .row .stats { margin-left: 0; width: 100%; justify-content: space-between; gap: 12px; margin-top: 8px; padding-top: 12px; border-top: 1px solid var(--c-border); }
      .row .stat { text-align: left; min-width: 0; flex: 1; }
      .row .tag { margin-right: 8px; }
      .row .desc { width: 100%; }
    }
    @media (max-width: 480px) {
      body { padding: 24px 14px 60px; }
      h1 { font-size: 22px; margin-bottom: 4px; }
      .subtitle { font-size: 12px; margin-bottom: 24px; }
      .summary-cards { gap: 8px; }
      .kpi-card { padding: 18px 16px 16px; }
      .kpi-card .kpi-num { font-size: 24px; }
      .kpi-card .kpi-label { font-size: 12px; margin-bottom: 8px; }
      .kpi-card .kpi-sub { font-size: 10px; }
      .row { padding: 14px 16px; }
      .row .stat .num { font-size: 15px; }
      .row .stat .label { font-size: 10px; }
      .filter-btn { padding: 6px 10px; font-size: 11px; }
    }
  </style>
</head>
