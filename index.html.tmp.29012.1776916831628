      '흐레카': { name:'흐레카(2025)', year:2025, type:'오프라인(B2B)', budget:28440000, actual:19434768, adCost:1130362, applicants:470, attendees:178, resume:null, satisfaction:'3.94/5', okaBang:null, kpiTarget:300, kpi:'156.7%', cpaTotal:41351, cpaAd:2405, period:'11.12', channels:'IAM 배너' },
      '퇴근후이력서': { name:'퇴근 후 이력서', year:2025, type:'오프라인', budget:13750000, actual:null, adCost:null, applicants:702, attendees:72, resume:586, satisfaction:null, okaBang:null, kpiTarget:1000, kpi:'58.6%', cpaTotal:null, cpaAd:null, period:'12.16~18', channels:'미정산' },
      '커리어컨퍼런스': { name:'커리어 컨퍼런스(2026)', year:2026, type:'웨비나', budget:9695588, actual:9695588, adCost:4905722, applicants:1566, attendees:562, resume:110, satisfaction:'4.33/5', okaBang:null, kpiTarget:5000, kpi:'31.5%', cpaTotal:6192, cpaAd:3133, period:'03.26', channels:'META' },
      '데브콘': { name:'데브콘(2026)', year:2026, type:'웨비나', budget:6000000, actual:null, adCost:4498434, applicants:1511, attendees:null, resume:308, satisfaction:null, okaBang:null, kpiTarget:1500, kpi:'100.7%', cpaTotal:null, cpaAd:2977, period:'04.23', channels:'META + CRM + 게임잡' }
    };
    var allEvents = Object.values(DB);

    function fmt(n) { return n !== null && n !== undefined ? Number(n).toLocaleString() : '—'; }

    // 단계별 챗봇
    function addMsg(text, isUser) {
      var msgs = document.getElementById('ai-messages');
      var div = document.createElement('div');
      div.style.cssText = isUser
        ? 'background:#3182F6;color:#fff;border-radius:12px;padding:10px 14px;font-size:13px;align-self:flex-end;max-width:80%'
        : 'background:#f2f4f6;border-radius:12px;padding:10px 14px;font-size:13px;color:#333D4B;align-self:flex-start;max-width:85%;user-select:text;line-height:1.6';
      div.innerHTML = text;
      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
      return div;
    }
    function addChips(options, callback) {
      var msgs = document.getElementById('ai-messages');
      var wrap = document.createElement('div');
      wrap.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;align-self:flex-start';
      options.forEach(function(opt) {
        var btn = document.createElement('button');
        btn.className = 'ai-chip';
        btn.textContent = opt;
        btn.onclick = function() { wrap.remove(); callback(opt); };
        wrap.appendChild(btn);
      });
      msgs.appendChild(wrap);
      msgs.scrollTop = msgs.scrollHeight;
    }

    var eventNames = ['밋업(25)', '흐레카(25)', '이력서(25)', '컨퍼런스(26)', '데브콘(26)', '전체 비교'];
    var eventKeys = { '밋업(25)':'커리어데이', '흐레카(25)':'흐레카', '이력서(25)':'퇴근후이력서', '컨퍼런스(26)':'커리어컨퍼런스', '데브콘(26)':'데브콘' };

    function aiStep1(topic) {
      var step0 = document.getElementById('ai-step0');
      if (step0) step0.remove();
      addMsg(topic === 'workfest' ? 'Work Fest 추천' : topic, true);

      if (topic === 'workfest') {
        addMsg('목표 이력서 <b>1,000건</b><br>→ 필요 신청 약 <b>1,200명</b><br>→ 광고비 <b>350~500만</b><br>→ 총 예산 <b>1,200~1,500만</b>');
        addMsg('더 알아볼까요?');
        addChips(['광고비 상세', '경품 책정', '처음으로'], function(c) {
          if (c === '처음으로') resetChat();
          else aiStep1(c === '광고비 상세' ? '광고비' : '경품');
        });
        return;
      }
      addMsg('어떤 이벤트요?');
      addChips(eventNames, function(ev) { aiStep2(topic, ev); });
    }

    function aiStep2(topic, eventName) {
      addMsg(eventName, true);
      if (eventName === '전체 비교') {
        var answer = analyzeQuestion(topic === '신청단가' ? '단가' : topic === '신청 단가' ? '단가' : topic);
        addMsg(answer);
      } else {
        var key = eventKeys[eventName];
        var e = DB[key];
        if (!e) { addMsg('데이터 없음'); return; }
        var t = topic.toLowerCase();
        if (t.match(/광고/)) addMsg(e.adCost ? '<b>' + fmt(e.adCost) + '원</b><br>채널: ' + e.channels : '미정산');
        else if (t.match(/경품/)) addMsg('상세 대시보드에서 확인해주세요');
        else if (t.match(/단가/)) addMsg('총 단가: <b>' + (e.cpaTotal ? fmt(e.cpaTotal) + '원' : '미정산') + '</b>' + (e.cpaAd ? '<br>광고 단가: ' + fmt(e.cpaAd) + '원' : ''));
        else if (t.match(/예산/)) addMsg('품의 <b>' + fmt(e.budget) + '원</b><br>실제 ' + (e.actual ? '<b>' + fmt(e.actual) + '원</b> (' + Math.round(e.actual/e.budget*100) + '%)' : '미정산'));
        else if (t.match(/이력서/)) addMsg(e.resume ? '<b>' + fmt(e.resume) + '명</b> (전환율 ' + (e.resume/e.applicants*100).toFixed(1) + '%)' : '해당없음');
        else if (t.match(/kpi/i)) addMsg('<b>' + e.kpi + '</b> (목표 ' + fmt(e.kpiTarget) + ')');
        else if (t.match(/만족/)) addMsg(e.satisfaction || '미수집');
        else addMsg('해당 데이터 없음');
      }
      addMsg('더 궁금한 거 있으세요?');
      addChips(['다른 항목', '다른 이벤트', '처음으로'], function(c) {
        if (c === '처음으로') resetChat();
        else if (c === '다른 항목') { addMsg('무엇이 궁금하세요?'); addChips(['광고비','경품','신청단가','예산','이력서','KPI','만족도'], function(t){ aiStep1(t); }); }
        else { addMsg('어떤 이벤트요?'); addChips(eventNames, function(ev){ aiStep2(topic, ev); }); }
      });
    }

    function resetChat() {
      var msgs = document.getElementById('ai-messages');
      msgs.innerHTML = '';
      addMsg('무엇이 궁금하세요?');
      addChips(['광고비','경품','신청 단가','예산','이력서','KPI','만족도','Work Fest 추천'], function(t) {
        aiStep1(t === 'Work Fest 추천' ? 'workfest' : t);
      });
    }

    function analyzeQuestion(q) {
      q = q.toLowerCase();
      var L = function(t){return t;};

      if (q.match(/광고비|광고 비|ad/)) {
        var r = '밋업 <b>500만</b> · 흐레카 <b>113만</b> · 컨퍼런스 <b>491만</b> · 데브콘 <b>450만</b>';
        if (q.match(/work|워크|5월/)) r += '<br><br>→ Work Fest 추천: <b>350~500만</b>';
        return r;
      }
      if (q.match(/경품|상품|선물|굿즈/)) {
        return '밋업 <b>284만</b> · 흐레카 <b>475만</b> · 이력서 <b>400만</b> · 컨퍼런스 <b>53만</b><br><br>인당 평균 <b>2,731원</b>';
      }
      if (q.match(/신청.?단가|cpa|단가/)) {
        return '밋업 <b>9,724원</b> · 흐레카 <b>41,351원</b> · 컨퍼런스 <b>6,192원</b><br>광고 기준: 밋업 2,961원 · 흐레카 2,405원 · 컨퍼런스 3,133원 · <b>데브콘 2,977원</b>';
      }
      if (q.match(/예산|budget|품의|집행|비용/)) {
        return '밋업 2,038만 → <b>1,641만</b>(80%)<br>흐레카 2,844만 → <b>1,943만</b>(68%)<br>이력서 1,375만 → 미정산<br>컨퍼런스 970만 → <b>970만</b>(100%)';
      }
      if (q.match(/이력서|resume|업데이트|전환/)) {
        return '이력서(25) <b>586명</b> 전환율 83.5%<br>밋업 <b>117명</b> 6.9%<br>컨퍼런스 <b>110명</b> 7.0%<br>데브콘 <b>308명</b> 20.4%';
      }
      if (q.match(/kpi|달성|목표/)) {
        return '밋업 <b>563%</b> · 흐레카 <b>157%</b> · 이력서 <b>59%</b><br>컨퍼런스 <b>32%</b> · 데브콘 <b>101%</b>';
      }
      if (q.match(/만족/)) {
        return '밋업 <b>84%</b> · 흐레카 <b>3.94/5</b> · 컨퍼런스 <b>4.33/5</b>';
      }
      if (q.match(/비교|전체|요약/)) {
        return '<table style="width:100%;font-size:11px;border-collapse:collapse"><tr style="background:#f2f4f6"><th style="padding:5px;text-align:left">이벤트</th><th style="text-align:right;padding:5px">신청</th><th style="text-align:right;padding:5px">이력서</th><th style="text-align:right;padding:5px">단가</th></tr>' +
        allEvents.map(function(e){return '<tr style="border-bottom:1px solid #f2f4f6"><td style="padding:5px">'+e.name.replace(/\(.*\)/,'')+'</td><td style="text-align:right;padding:5px">'+fmt(e.applicants)+'</td><td style="text-align:right;padding:5px">'+fmt(e.resume)+'</td><td style="text-align:right;padding:5px">'+(e.cpaTotal?fmt(e.cpaTotal)+'원':'—')+'</td></tr>';}).join('') + '</table>';
      }
      if (q.match(/work\s?fest|워크|5월/)) {
        return '목표 이력서 1,000건<br>→ 필요 신청 <b>~1,200명</b><br>→ 광고비 <b>350~500만</b><br>→ 총 예산 <b>1,200~1,500만</b>';
      }
      return '키워드로 물어보세요: <b>광고비 · 경품 · 단가 · 예산 · 이력서 · KPI · 비교 · Work Fest · 만족도</b>';
    }

    function sendAiQuestion() {
      var input = document.getElementById('ai-input');
      var q = input.value.trim();
      if (!q) return;
      input.value = '';
      addMsg(q, true);
      var answer = analyzeQuestion(q);
      addMsg(answer);
      addMsg('더 궁금한 거 있으세요?');
      addChips(['처음으로'], function() { resetChat(); });
    }

    function selectAllMetrics(checked) {
      document.querySelectorAll('#metric-checks input').forEach(function(cb) { cb.checked = checked; });
      updateCompare();
    }

    function fmt(v) {
      if (v === null || v === undefined) return '<span style="color:#B0B8C1">—</span>';
      if (typeof v === 'string') return v;
      return v.toLocaleString() + '원';
    }

    function updateCompare() {
      var selected = []; var metrics = [];
      document.querySelectorAll('#compare-checks input:checked').forEach(function(cb) { selected.push(cb.value); });
      document.querySelectorAll('#metric-checks input:checked').forEach(function(cb) { metrics.push(cb.value); });

      var result = document.getElementById('compare-result');
      if (selected.length < 2) { result.style.display = 'none'; return; }
      result.style.display = '';

      var html = '<thead><tr><th style="min-width:120px">지표</th>';
      selected.forEach(function(key) { html += '<th style="text-align:right;min-width:130px">' + compareData[key].name + '</th>'; });
      html += '</tr></thead><tbody>';

      metrics.forEach(function(m) {
        html += '<tr><td>' + metricLabels[m] + '</td>';
        selected.forEach(function(key) {
          var d = compareData[key];
          var val;
          if (m === 'cpa') { val = (d.adCost && d.applicants) ? Math.round(d.adCost / d.applicants).toLocaleString() + '원' : null; }
          else if (m === 'cpAttend') { val = (d.adCost && d.attendees) ? Math.round(d.adCost / d.attendees).toLocaleString() + '원' : null; }
          else if (m === 'budget' || m === 'actual' || m === 'adCost') { val = d[m]; }
          else if (m === 'applicants' || m === 'attendees' || m === 'resumeUpdate' || m === 'okaBang') { val = d[m] !== null ? d[m].toLocaleString() + '명' : null; }
          else { val = d[m]; }
          html += '<td>' + fmt(val) + '</td>';
        });
        html += '</tr>';
      });
      html += '</tbody>';
      document.getElementById('compare-table').innerHTML = html;
    }
  </script>
</body>
